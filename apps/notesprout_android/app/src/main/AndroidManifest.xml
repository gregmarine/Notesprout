<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- API 29: legacy external storage write access -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <!-- API 30+: unrestricted file manager access for /Documents/NoteSprout/ -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />

    <application
        android:requestLegacyExternalStorage="true"
        android:name=".NoteSproutApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.NoteSprout">

        <!-- Theme QA — launcher entry point -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="stateHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Drawing screen — prevent recreation on rotation/resize so bitmap survives -->
        <activity
            android:name=".DrawingActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

        <!-- Page index screen — full-screen grid of page snapshots -->
        <activity
            android:name=".PageIndexActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

    </application>

</manifest>
