<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".NotesproutApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/backup_rules"
        android:fullBackupContent="@xml/backup_descriptor"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Notesprout">

        <!-- Theme QA — launcher entry point -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:windowSoftInputMode="stateHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Tap a .soil file — path-pattern match covers any MIME type the file manager sends -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" />
                <data android:scheme="content" />
                <data android:mimeType="*/*" />
                <data android:pathPattern=".*\\.soil" />
            </intent-filter>
            <!-- Explicit MIME type fallbacks for file managers that set them -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/x-notesprout-soil" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="application/x-notesprout-soil" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="content" android:mimeType="application/octet-stream" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="file" android:mimeType="application/octet-stream" />
            </intent-filter>
            <!-- Share a .soil to Notesprout -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/x-notesprout-soil" />
            </intent-filter>
            <!-- Share a .soil to Notesprout (older exports / other sources) -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/octet-stream" />
            </intent-filter>
        </activity>

        <!-- Notebook screen — prevent recreation on rotation/resize so bitmap survives -->
        <activity
            android:name=".NotebookActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

        <!-- Page index screen — full-screen grid of page snapshots -->
        <activity
            android:name=".PageIndexActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

        <!-- Notebook picker — folder-browse list for cross-notebook page copy/move destination -->
        <activity
            android:name=".NotebookPickerActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

        <!-- Link target picker — full-screen chrome + page-thumbnail grid -->
        <activity
            android:name=".LinkTargetPickerActivity"
            android:exported="false"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

        <!-- Template browser — full-screen folder/template grid (manage + pick modes) -->
        <activity
            android:name=".TemplateBrowserActivity"
            android:exported="false"
            android:theme="@style/Theme.Notesprout"
            android:windowSoftInputMode="stateHidden" />

        <!-- Encryption settings — global passphrase management (status, forget, change) -->
        <activity
            android:name=".EncryptionSettingsActivity"
            android:exported="false"
            android:windowSoftInputMode="stateHidden" />

        <!-- Backup settings — local + Google Drive destination configuration -->
        <activity
            android:name=".BackupSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Notesprout"
            android:windowSoftInputMode="stateHidden" />

        <!-- Drive OAuth WebView — opens Google consent page, intercepts localhost redirect -->
        <activity
            android:name=".DriveAuthActivity"
            android:exported="false"
            android:theme="@style/Theme.Notesprout"
            android:windowSoftInputMode="stateHidden" />

        <!-- Scratch pad — translucent floating window over any launch surface -->
        <activity
            android:name=".ScratchpadActivity"
            android:exported="false"
            android:theme="@style/Theme.Notesprout.Scratchpad"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

        <!-- Sticky note editor — translucent in-memory popup over NotebookActivity -->
        <activity
            android:name=".StickyNoteEditorActivity"
            android:exported="false"
            android:theme="@style/Theme.Notesprout.Scratchpad"
            android:configChanges="orientation|keyboardHidden|screenSize|smallestScreenSize|screenLayout|density"
            android:windowSoftInputMode="stateHidden" />

        <!-- FileProvider — exposes cacheDir PDF exports to the share sheet -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
