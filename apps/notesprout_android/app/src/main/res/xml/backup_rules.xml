<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31+): cloud backup and device-transfer rules.
     .soil and template files live in getExternalFilesDir — excluded from backup by the OS.
     Only the cache dir (exported PDFs) needs an explicit exclude. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="cache" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="cache" />
    </device-transfer>
</data-extraction-rules>
