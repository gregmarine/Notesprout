<?xml version="1.0" encoding="utf-8"?>
<!-- Selected-state background for the current heading level in the heading-type submenu.
     1dp inkBlack border, 4dp corner radius, transparent fill (no <solid>).
     inkBlack (#000000) is used instead of borderGray (#CCCCCC): borderGray is invisible on e-ink. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <stroke
        android:width="1dp"
        android:color="@color/inkBlack" />

    <corners android:radius="4dp" />

</shape>
