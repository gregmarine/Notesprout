<?xml version="1.0" encoding="utf-8"?>
<!-- Left-anchored toolbar: white background with a 1dp inkBlack right (inner) border.
     Negative insets push the stroke rect outside the view bounds on three sides
     so only the right edge of the stroke is visible. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/paperWhite" />
        </shape>
    </item>
    <item
        android:left="-2dp"
        android:top="-2dp"
        android:bottom="-2dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/inkBlack" />
        </shape>
    </item>
</layer-list>
