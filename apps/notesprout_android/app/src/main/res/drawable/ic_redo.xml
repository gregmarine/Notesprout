<?xml version="1.0" encoding="utf-8"?>
<!-- Redo icon: clockwise curved arrow — mirror of ic_undo.
     Arc sweeps from the left side rightward (via top), with a downward arrowhead at the right end.
     strokeWidth 2dp, no fill, inkBlack. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Clockwise arc: starts at left (6,13), sweeps via top to right (18,13).
         SVG arc: rx=6 ry=6, large-arc=0, sweep=1 (clockwise). -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M6,13 A6,6 0 0,1 18,13" />

    <!-- Arrowhead at the right end of the arc, pointing down-right. -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M15,10 L18,13 L21,10" />

</vector>
