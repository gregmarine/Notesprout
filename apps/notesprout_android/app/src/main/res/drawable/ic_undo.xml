<?xml version="1.0" encoding="utf-8"?>
<!-- Undo icon: counter-clockwise curved arrow.
     Arc sweeps from the right side leftward (via top), with a downward arrowhead at the left end.
     strokeWidth 2dp, no fill, inkBlack. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Counter-clockwise arc: starts at right (18,13), sweeps via top to left (6,13).
         SVG arc: rx=6 ry=6, large-arc=0, sweep=0 (counter-clockwise). -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M18,13 A6,6 0 0,0 6,13" />

    <!-- Arrowhead at the left end of the arc, pointing down-left. -->
    <path
        android:strokeColor="#000000"
        android:strokeWidth="2"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M3,10 L6,13 L9,10" />

</vector>
