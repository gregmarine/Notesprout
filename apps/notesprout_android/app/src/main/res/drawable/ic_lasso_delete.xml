<?xml version="1.0" encoding="utf-8"?>
<!-- Tabler trash icon (outline/trash.svg): lid bar across top, two inner vertical lines,
     trapezoidal body with rounded base, handle/cap above lid. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Lid bar: horizontal line across top -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@color/inkBlack"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M4,7 L20,7"/>

    <!-- Left inner vertical line -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@color/inkBlack"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M10,11 L10,17"/>

    <!-- Right inner vertical line -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@color/inkBlack"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M14,11 L14,17"/>

    <!-- Body: from lid down to rounded base -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@color/inkBlack"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M5,7 L6,19 A2,2,0,0,0,8,21 H16 A2,2,0,0,0,18,19 L19,7"/>

    <!-- Handle/cap above lid -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="@color/inkBlack"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M9,7 V4 A1,1,0,0,1,10,3 H14 A1,1,0,0,1,15,4 V7"/>

</vector>
