<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paperWhite">

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <!--
        Picker toolbar: shown only in destination picker mode (Copy/Move notebook or folder).
        Hidden by default; VISIBLE when destinationPickerState != None.
    -->
    <LinearLayout
        android:id="@+id/pickerToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/paperWhite"
        android:gravity="center_vertical"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPickerCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="Cancel"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:background="@null"
            android:stateListAnimator="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <TextView
            android:id="@+id/pickerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:gravity="center" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPickerConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:text="Copy here"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:textStyle="bold"
            android:background="@null"
            android:stateListAnimator="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </LinearLayout>

    <View
        android:id="@+id/pickerToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack"
        android:visibility="gone" />

    <!--
        Pinned toolbar: shown only in pinned browse mode.
        Hidden by default; VISIBLE when isPinnedMode is true.
    -->
    <LinearLayout
        android:id="@+id/pinnedToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/paperWhite"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/pinnedTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:text="Pinned"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPinnedCancel"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_x"
            android:contentDescription="Exit pinned view" />

    </LinearLayout>

    <View
        android:id="@+id/pinnedToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack"
        android:visibility="gone" />

    <!--
        Breadcrumb bar: always visible for consistent layout.
        Back button and chips are hidden at root; chips populate when navigated into a subfolder.
    -->
    <LinearLayout
        android:id="@+id/breadcrumbBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/paperWhite"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBreadcrumbBack"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Go up one folder"
            android:visibility="invisible" />

        <!-- 1dp vertical divider between back button and breadcrumb chips -->
        <View
            android:id="@+id/breadcrumbBackDivider"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="@color/inkBlack"
            android:visibility="invisible" />

        <HorizontalScrollView
            android:id="@+id/breadcrumbScrollView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/breadcrumbContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPinned"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_pinned"
            android:contentDescription="Pinned notebooks" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSearch"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_search"
            android:contentDescription="Search notebooks" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnClearSearch"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_x"
            android:contentDescription="Clear search"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSort"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_filter"
            android:contentDescription="Sort" />

    </LinearLayout>

    <!-- 1dp separator below breadcrumb bar — always visible since the bar is always visible -->
    <View
        android:id="@+id/breadcrumbDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <!--
        Grid area: fills all vertical space above the bottom bar.
        Cards and the empty-state message are added programmatically.
    -->
    <FrameLayout
        android:id="@+id/gridContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!--
        Bottom bar (sw360dp variant): pagination anchored to start, action buttons right-aligned.
        On narrow screens (e.g. Palma2 Pro) there is not enough room to centre the pagination
        group when the action buttons are also present, so we left-anchor it instead.
    -->
    <RelativeLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/paperWhite">

        <!-- Top border (1dp inkBlack) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/inkBlack"
            android:layout_alignParentTop="true" />

        <!--
            Pagination group: |<  <  n/n  >  >|
            Left-anchored on narrow screens so it does not overlap the action buttons.
        -->
        <LinearLayout
            android:id="@+id/paginationGroup"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_alignParentStart="true"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnFirstPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_page_first"
                android:contentDescription="First page" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnPrevPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_page_prev"
                android:contentDescription="Previous page" />

            <TextView
                android:id="@+id/tvPage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="72dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="normal"
                android:textColor="@color/inkBlack"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="1/1" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnNextPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_page_next"
                android:contentDescription="Next page" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnLastPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_page_last"
                android:contentDescription="Last page" />

        </LinearLayout>

        <!-- Right-side action buttons: New Notebook + New Folder, right-aligned -->
        <LinearLayout
            android:id="@+id/actionButtonsGroup"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnNewNotebook"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_new_notebook"
                android:contentDescription="New notebook" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnNewFolder"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_folder_plus"
                android:contentDescription="New folder" />

        </LinearLayout>

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

</LinearLayout>
