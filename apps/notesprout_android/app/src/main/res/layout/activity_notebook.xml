<?xml version="1.0" encoding="utf-8"?>
<!-- Notebook screen — native equivalent of DrawingScreen in Flutter.
     Root FrameLayout: drawing container fills the entire screen; toolbar and page
     indicator overlay on top.
     z-order: drawingContainer (bottom) → toolbar → tvPageIndicator (top). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paperWhite">

    <!-- Drawing view is added here programmatically -->
    <FrameLayout
        android:id="@+id/drawingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/paperWhite" />

    <!-- Toolbar floats above the canvas.
         On BOOX, setLimitRect excludes this region from pen input.
         Height is 56dp to comfortably fit 44dp icon buttons + padding.
         toolbar_background drawable provides the 1dp inkBlack bottom border.
         Buttons are declared here once; ToolbarLayoutManager arranges them per ToolbarConfig
         (order, visibility, auto-dividers, and the trailing weighted spacer before the overflow
         controls). Group dividers and the spacer are generated in code — not declared here. Only
         dividerOverflow + btnOverflow remain inline, as the overflow manager references them. -->
    <LinearLayout
        android:id="@+id/drawingToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="@drawable/toolbar_background_top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Close button: exits the notebook -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnClose"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_close"
            android:contentDescription="Close notebook" />

        <!-- Recent notebooks button: opens the recents switch dialog -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnRecents"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_clock"
            android:contentDescription="Recent notebooks" />

        <!-- Table of Contents button -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnToc"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_toc"
            android:contentDescription="Table of Contents" />

        <!-- Cover button: set notebook cover image -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnCover"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_polaroid"
            android:contentDescription="Set cover" />

        <!-- Export button: export notebook to PDF -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnExport"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_export"
            android:contentDescription="Export notebook" />

        <!-- Pin button: pin/unpin this notebook -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPin"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_pinned"
            android:contentDescription="Pin notebook" />

        <!-- Lock button: encrypt this notebook (visible only when unencrypted) -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLock"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_lock"
            android:contentDescription="Encrypt notebook" />

        <!-- Lock-off button: decrypt this notebook (visible only when encrypted) -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLockOff"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_lock_off"
            android:contentDescription="Decrypt notebook" />

        <!-- Pen tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPen"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_pen"
            android:contentDescription="Pen tool" />

        <!-- Eraser tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnEraser"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_eraser"
            android:contentDescription="Eraser tool" />

        <!-- Lasso eraser tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoEraser"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_lasso_eraser"
            android:contentDescription="Lasso eraser" />

        <!-- Erase all -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnEraseAll"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_erase_all"
            android:contentDescription="Erase all" />

        <!-- Insert text object -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnInsertText"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_text_recognition"
            android:contentDescription="Insert text" />

        <!-- Insert line objects -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnInsertLines"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_density_small"
            android:contentDescription="Insert lines" />

        <!-- Lasso selection tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLasso"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_lasso"
            android:contentDescription="Lasso selection" />

        <!-- Undo -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnUndo"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_undo"
            android:contentDescription="Undo" />

        <!-- Redo -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnRedo"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_redo"
            android:contentDescription="Redo" />

        <!-- Template picker -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnTemplate"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_template"
            android:contentDescription="Template" />

        <!-- Page index — same group as template, no separator -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPageIndex"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_files"
            android:contentDescription="Page index" />

        <!-- Insert page before current -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnInsertPageBefore"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_insert_page_before"
            android:contentDescription="Insert page before" />

        <!-- Insert page after current -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnInsertPageAfter"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_insert_page_after"
            android:contentDescription="Insert page after" />

        <!-- Delete page -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnDeletePage"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_page_delete"
            android:contentDescription="Delete page" />

        <!-- Copy page — same group as page management controls -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnCopyPage"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_copy_page"
            android:contentDescription="Copy page" />

        <!-- Paste page — same group -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPastePage"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_paste_page"
            android:contentDescription="Paste page" />

        <!-- Customize toolbar (gear) — opens the reorder / show-hide dialog.
             Customizable + overflow-eligible like any other button. -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnToolbarSettings"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_adjustments"
            android:contentDescription="Customize toolbar" />

        <!-- Overflow group divider — visible only when overflow button is shown -->
        <View
            android:id="@+id/dividerOverflow"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="@color/inkBlack"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone"/>

        <!-- Overflow button — shows overflowed toolbar items in a menu below the toolbar -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnOverflow"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_dots"
            android:contentDescription="More actions"
            android:visibility="gone"/>

    </LinearLayout>

    <!-- Overflow menu — appears directly below the toolbar when overflow is active.
         Built dynamically by ToolbarOverflowManager: one or more horizontal rows of
         overflowed buttons, wrapped to fit the toolbar width.
         Pinned to top via layout_gravity + layout_marginTop matching the toolbar height. -->
    <LinearLayout
        android:id="@+id/overflowMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="56dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@drawable/shape_bordered"
        android:elevation="0dp"/>

    <!-- Page indicator — overlay in the lower-right corner of the drawing surface.
         Not inside the toolbar; rendered above the canvas via FrameLayout z-order. -->
    <TextView
        android:id="@+id/tvPageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:text="1 / 1"
        android:textColor="@color/inkBlack"
        android:textSize="16sp" />

    <!-- Floating selection context toolbar — appears below (or above) the lasso selection box.
         Positioned programmatically in NotebookActivity.updateFloatingSelectionToolbar().
         Contains actions that operate on the current lasso selection. -->
    <LinearLayout
        android:id="@+id/floatingSelectionToolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/shape_bordered"
        android:padding="4dp"
        android:elevation="0dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoCopy"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_copy_plus"
            android:contentDescription="Copy selection" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoCut"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_cut"
            android:contentDescription="Cut selection" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoDelete"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_lasso_delete"
            android:contentDescription="Delete selection" />

        <!-- Separator before heading actions — hidden when selection contains headings -->
        <View
            android:id="@+id/headingDivider"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/inkBlack"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnMakeHeading"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_heading"
            android:contentDescription="Make Heading"
            android:visibility="gone" />

        <!-- S4: shown when selection is a single heading; opens headingTypeSubmenu in CHANGE mode -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHeadingMenu"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_heading"
            android:contentDescription="Change heading level"
            android:visibility="gone" />

        <!-- Separator before text conversion action — visible only for pure-stroke selections -->
        <View
            android:id="@+id/textConvertDivider"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/inkBlack"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnConvertText"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_text_recognition"
            android:contentDescription="Convert to Text"
            android:visibility="gone" />

        <!-- Separator before align actions — visible only for multi-object non-stroke selections -->
        <View
            android:id="@+id/alignDivider"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/inkBlack"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnAlignLeft"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_box_align_left"
            android:contentDescription="Align left and distribute vertically"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnAlignTop"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_box_align_top"
            android:contentDescription="Align top and distribute horizontally"
            android:visibility="gone" />

        <!-- Separator before link actions — visible when add or remove link is shown -->
        <View
            android:id="@+id/linkDivider"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/inkBlack"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLink"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_link_plus"
            android:contentDescription="Make Link"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLinkEdit"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_link"
            android:contentDescription="Edit Link"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnUnlink"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_link_off"
            android:contentDescription="Remove Link"
            android:visibility="gone" />

        <View
            android:id="@+id/snapDivider"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/inkBlack" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSnapToggle"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_snap_on"
            android:contentDescription="Toggle snap to guides" />

    </LinearLayout>

    <!-- Heading-type submenu — appears below (or above) the selection box when the heading button
         in the floating selection toolbar is tapped. Positioned programmatically via positionPopover().
         Shared between S3 (pure-stroke selection → convert to H1/H2/H3) and S4 (single-heading
         selection → change level / un-heading). The un-heading button is hidden in S3. -->
    <LinearLayout
        android:id="@+id/headingTypeSubmenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/shape_bordered"
        android:padding="4dp"
        android:elevation="0dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHeadingH1"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_h_1"
            android:contentDescription="Heading 1" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHeadingH2"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_h_2"
            android:contentDescription="Heading 2" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHeadingH3"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_h_3"
            android:contentDescription="Heading 3" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnHeadingUnheading"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_heading_off"
            android:contentDescription="Remove Heading"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Lasso button popup toolbar — anchored below btnLasso.
         Appears when the user taps the active lasso button while the clipboard has content.
         Dismissed on any tool switch, gesture start, paste, or outside tap. -->
    <LinearLayout
        android:id="@+id/lassoPopupToolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/shape_bordered"
        android:padding="4dp"
        android:elevation="0dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoClearClipboard"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_clipboard_x"
            android:contentDescription="Clear lasso clipboard" />

    </LinearLayout>

    <!-- Opening overlay — shown only while an encrypted notebook is unlocking + loading the first
         page. Intercepts all touches while visible. Never shown for plaintext notebooks. -->
    <FrameLayout
        android:id="@+id/openingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true"
        android:background="@color/paperWhite">

        <LinearLayout
            android:layout_gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/shape_bordered"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opening…"
                android:textColor="@color/inkBlack"
                android:textSize="16sp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
