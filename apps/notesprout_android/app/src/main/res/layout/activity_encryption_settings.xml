<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paperWhite"
    android:fitsSystemWindows="true">

    <!-- Top border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/paperWhite"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBack"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Back"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Encryption"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Resume rotation banner — hidden until S6 wires the rotation marker -->
            <LinearLayout
                android:id="@+id/resumeRotationBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/shape_bordered"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="A passphrase rotation is in progress."
                    android:textSize="14sp"
                    android:textColor="@color/inkBlack" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnResumeRotation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resume"
                    android:textSize="14sp"
                    android:textColor="@color/inkBlack"
                    android:textAllCaps="false"
                    android:background="@drawable/shape_bordered"
                    android:stateListAnimator="@null"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginStart="12dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp" />

            </LinearLayout>

            <!-- Status row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Global passphrase"
                    android:textSize="16sp"
                    android:textColor="@color/inkBlack" />

                <TextView
                    android:id="@+id/tvGlobalStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/inkBlack"
                    android:textStyle="bold"
                    android:text="Not set" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/inkBlack" />

            <!-- Count row -->
            <TextView
                android:id="@+id/tvGlobalCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:textSize="14sp"
                android:textColor="@color/inkLight"
                android:text="0 notebooks use the global passphrase" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/inkBlack" />

            <!-- Change Global Passphrase button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnChangeGlobalPassphrase"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Change Global Passphrase…"
                android:textSize="16sp"
                android:textColor="@color/inkBlack"
                android:textAllCaps="false"
                android:background="@drawable/shape_bordered"
                android:stateListAnimator="@null"
                android:minWidth="0dp"
                android:minHeight="0dp" />

            <!-- Forget button -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnForgetPassphrase"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:text="Forget on This Device"
                android:textSize="16sp"
                android:textColor="@color/inkBlack"
                android:textAllCaps="false"
                android:background="@drawable/shape_bordered"
                android:stateListAnimator="@null"
                android:minWidth="0dp"
                android:minHeight="0dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Bottom border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

</LinearLayout>
