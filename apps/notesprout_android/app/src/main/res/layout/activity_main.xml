<?xml version="1.0" encoding="utf-8"?>
<!-- ThemeQA screen — native equivalent of AppThemeTestScreen in Flutter -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paperWhite"
    android:orientation="vertical">

    <!-- Toolbar: white bg + 1dp inkBlack bottom border, no elevation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Theme QA"
            android:textColor="@color/inkBlack"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDraw"
            style="@style/Widget.NoteSprout.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Draw" />

    </LinearLayout>

    <!-- Scrollable body -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- ── Typography ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Typography"
                style="@style/TextAppearance.NoteSprout.LabelLarge" />
            <View android:layout_width="match_parent" android:layout_height="4dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/inkBlack" />
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Display Large"
                style="@style/TextAppearance.NoteSprout.DisplayLarge" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Headline Large"
                style="@style/TextAppearance.NoteSprout.HeadlineLarge" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Headline Medium"
                style="@style/TextAppearance.NoteSprout.HeadlineMedium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Title Large"
                style="@style/TextAppearance.NoteSprout.TitleLarge" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Body Large"
                style="@style/TextAppearance.NoteSprout.BodyLarge" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Body Medium"
                style="@style/TextAppearance.NoteSprout.BodyMedium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Body Small (secondary)"
                style="@style/TextAppearance.NoteSprout.BodySmall" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Label Large"
                style="@style/TextAppearance.NoteSprout.LabelLarge" />

            <!-- ── Buttons ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Buttons"
                style="@style/TextAppearance.NoteSprout.LabelLarge" />
            <View android:layout_width="match_parent" android:layout_height="4dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/inkBlack" />
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/Widget.NoteSprout.ElevatedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Elevated Button" />

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/Widget.NoteSprout.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Outlined Button" />

            <View android:layout_width="match_parent" android:layout_height="8dp" />

            <androidx.appcompat.widget.AppCompatButton
                style="@style/Widget.NoteSprout.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Text Button" />

            <!-- ── Card ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Card"
                style="@style/TextAppearance.NoteSprout.LabelLarge" />
            <View android:layout_width="match_parent" android:layout_height="4dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/inkBlack" />
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_bordered"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Card Title"
                    style="@style/TextAppearance.NoteSprout.TitleMedium" />
                <View android:layout_width="match_parent" android:layout_height="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Card body text — content lives here."
                    style="@style/TextAppearance.NoteSprout.BodyMedium" />
                <View android:layout_width="match_parent" android:layout_height="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Secondary caption"
                    style="@style/TextAppearance.NoteSprout.BodySmall" />

            </LinearLayout>

            <!-- ── Input ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Input"
                style="@style/TextAppearance.NoteSprout.LabelLarge" />
            <View android:layout_width="match_parent" android:layout_height="4dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/inkBlack" />
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <androidx.appcompat.widget.AppCompatEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_bordered"
                android:hint="Label"
                android:textColorHint="@color/inkLight"
                android:textColor="@color/inkBlack"
                android:textSize="14sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <!-- ── Divider ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Divider"
                style="@style/TextAppearance.NoteSprout.LabelLarge" />
            <View android:layout_width="match_parent" android:layout_height="4dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/inkBlack" />
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Above the divider"
                style="@style/TextAppearance.NoteSprout.BodyMedium" />
            <View android:layout_width="match_parent" android:layout_height="8dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/inkBlack" />
            <View android:layout_width="match_parent" android:layout_height="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Below the divider"
                style="@style/TextAppearance.NoteSprout.BodyMedium" />

            <!-- ── Palette ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Palette"
                style="@style/TextAppearance.NoteSprout.LabelLarge" />
            <View android:layout_width="match_parent" android:layout_height="4dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/inkBlack" />
            <View android:layout_width="match_parent" android:layout_height="12dp" />

            <!-- inkBlack -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/swatch_ink_black" />
                <View android:layout_width="12dp" android:layout_height="wrap_content" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="inkBlack"
                    style="@style/TextAppearance.NoteSprout.BodyMedium" />
            </LinearLayout>

            <!-- paperWhite -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/swatch_paper_white" />
                <View android:layout_width="12dp" android:layout_height="wrap_content" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="paperWhite"
                    style="@style/TextAppearance.NoteSprout.BodyMedium" />
            </LinearLayout>

            <!-- inkLight -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/swatch_ink_light" />
                <View android:layout_width="12dp" android:layout_height="wrap_content" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="inkLight"
                    style="@style/TextAppearance.NoteSprout.BodyMedium" />
            </LinearLayout>

            <!-- borderGray -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/swatch_border_gray" />
                <View android:layout_width="12dp" android:layout_height="wrap_content" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="borderGray"
                    style="@style/TextAppearance.NoteSprout.BodyMedium" />
            </LinearLayout>

            <!-- Bottom padding -->
            <View android:layout_width="match_parent" android:layout_height="32dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
