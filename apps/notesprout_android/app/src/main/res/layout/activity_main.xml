<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paperWhite">

    <!--
        Grid area: fills all vertical space above the bottom bar.
        Cards and the empty-state message are added programmatically.
    -->
    <FrameLayout
        android:id="@+id/gridContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!--
        Bottom bar: 1dp inkBlack top border, pagination centred, + button right-aligned.
        Height 72dp — fits 44dp icon buttons with comfortable vertical padding.
    -->
    <RelativeLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@color/paperWhite">

        <!-- Top border (1dp inkBlack) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/inkBlack"
            android:layout_alignParentTop="true" />

        <!--
            Pagination group: |<  <  n/n  >  >|
            Centered horizontally and vertically inside the bar.
        -->
        <LinearLayout
            android:id="@+id/paginationGroup"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_centerInParent="true"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnFirstPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_page_first"
                android:contentDescription="First page" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnPrevPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_page_prev"
                android:contentDescription="Previous page" />

            <TextView
                android:id="@+id/tvPage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="72dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="normal"
                android:textColor="@color/inkBlack"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="1/1" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnNextPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_page_next"
                android:contentDescription="Next page" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnLastPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_page_last"
                android:contentDescription="Last page" />

        </LinearLayout>

        <!-- New notebook button: right-aligned, vertically centred -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnNewNotebook"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_new_notebook"
            android:contentDescription="New notebook" />

    </RelativeLayout>

</LinearLayout>
