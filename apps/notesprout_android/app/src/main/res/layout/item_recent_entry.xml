<?xml version="1.0" encoding="utf-8"?>
<!-- One Recent Notebooks row: notebook name (TOC heading style), date/time below it
     in a smaller font, folder path below that at the same small size. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="8dp"
        android:paddingEnd="12dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvRecentName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/inkBlack"
            android:textSize="20sp"
            android:ellipsize="end"
            android:singleLine="true" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvRecentDateTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/inkLight"
            android:textSize="13sp"
            android:ellipsize="end"
            android:singleLine="true" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvRecentFolderPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/inkLight"
            android:textSize="13sp"
            android:ellipsize="end"
            android:singleLine="true" />

    </LinearLayout>

    <View
        android:id="@+id/recentItemSeparator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="24dp"
        android:background="@color/inkBlack" />

</LinearLayout>
