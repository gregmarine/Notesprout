<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp">

        <!-- Style row -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Style"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStyleSolid"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Solid"
                android:textSize="13sp"
                android:stateListAnimator="@null"
                android:background="@drawable/bg_toolbar_button"
                android:layout_marginEnd="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStyleDashed"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Dashed"
                android:textSize="13sp"
                android:stateListAnimator="@null"
                android:background="@drawable/bg_toolbar_button"
                android:layout_marginEnd="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStyleDotted"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Dotted"
                android:textSize="13sp"
                android:stateListAnimator="@null"
                android:background="@drawable/bg_toolbar_button" />

        </LinearLayout>

        <!-- Orientation row -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Orientation"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnOrientationHorizontal"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Horizontal"
                android:textSize="13sp"
                android:stateListAnimator="@null"
                android:background="@drawable/bg_toolbar_button"
                android:layout_marginEnd="4dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnOrientationVertical"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Vertical"
                android:textSize="13sp"
                android:stateListAnimator="@null"
                android:background="@drawable/bg_toolbar_button" />

        </LinearLayout>

        <!-- Stroke width -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stroke Width (dp)"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editStrokeWidth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_bordered"
            android:text="1"
            android:textColor="@color/inkBlack"
            android:textSize="14sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:inputType="numberDecimal"
            android:singleLine="true"
            android:layout_marginBottom="16dp" />

        <!-- Count -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Number of Lines"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editLineCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_bordered"
            android:text="5"
            android:textColor="@color/inkBlack"
            android:textSize="14sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:inputType="number"
            android:singleLine="true"
            android:layout_marginBottom="16dp" />

        <!-- Margins -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Margins (dp)"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:layout_marginBottom="6dp" />

        <!-- Top + Bottom margins -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Top"
                    android:textColor="@color/inkBlack"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/editMarginTop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_bordered"
                    android:text="44"
                    android:textColor="@color/inkBlack"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:inputType="numberDecimal"
                    android:singleLine="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bottom"
                    android:textColor="@color/inkBlack"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/editMarginBottom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_bordered"
                    android:text="44"
                    android:textColor="@color/inkBlack"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:inputType="numberDecimal"
                    android:singleLine="true" />
            </LinearLayout>

        </LinearLayout>

        <!-- Left + Right margins -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Left"
                    android:textColor="@color/inkBlack"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/editMarginLeft"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_bordered"
                    android:text="44"
                    android:textColor="@color/inkBlack"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:inputType="numberDecimal"
                    android:singleLine="true" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Right"
                    android:textColor="@color/inkBlack"
                    android:textSize="11sp"
                    android:layout_marginBottom="4dp" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/editMarginRight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/shape_bordered"
                    android:text="44"
                    android:textColor="@color/inkBlack"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:inputType="numberDecimal"
                    android:singleLine="true" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
