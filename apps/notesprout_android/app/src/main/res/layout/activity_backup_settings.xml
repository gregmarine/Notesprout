<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paperWhite"
    android:fitsSystemWindows="true">

    <!-- Top border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <!-- Title bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="@color/paperWhite"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBack"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Back"
            android:layout_marginStart="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Backup"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- ── Device folder name section ─────────────────────────────── -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This device's backup folder name"
                android:textSize="16sp"
                android:textColor="@color/inkBlack"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <androidx.appcompat.widget.AppCompatEditText
                android:id="@+id/etDeviceFolderName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/shape_bordered"
                android:padding="12dp"
                android:textSize="14sp"
                android:textColor="@color/inkBlack"
                android:inputType="textNoSuggestions"
                android:imeOptions="actionDone"
                android:singleLine="true" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaveDeviceName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Save Name"
                android:textSize="14sp"
                android:textColor="@color/inkBlack"
                android:textAllCaps="false"
                android:background="@drawable/shape_bordered"
                android:stateListAnimator="@null"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp"
                android:minHeight="0dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Used as the subfolder name inside your Google Drive backup folder."
                android:textSize="12sp"
                android:textColor="@color/inkLight" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/inkBlack"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Local destination section ───────────────────────────────── -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Local Backup"
                android:textSize="16sp"
                android:textColor="@color/inkBlack"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvLocalStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not configured"
                android:textSize="14sp"
                android:textColor="@color/inkLight"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnChooseLocal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Choose folder…"
                    android:textSize="14sp"
                    android:textColor="@color/inkBlack"
                    android:textAllCaps="false"
                    android:background="@drawable/shape_bordered"
                    android:stateListAnimator="@null"
                    android:minWidth="0dp"
                    android:minHeight="0dp" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchLocalEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Enabled"
                    android:textSize="14sp"
                    android:textColor="@color/inkBlack"
                    android:buttonTint="@color/inkBlack" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/inkBlack"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Google Drive destination section ───────────────────────── -->

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Google Drive Backup"
                android:textSize="16sp"
                android:textColor="@color/inkBlack"
                android:textStyle="bold"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tvDriveStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Not configured"
                android:textSize="14sp"
                android:textColor="@color/inkLight"
                android:paddingBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btnChooseDrive"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Choose folder…"
                    android:textSize="14sp"
                    android:textColor="@color/inkBlack"
                    android:textAllCaps="false"
                    android:background="@drawable/shape_bordered"
                    android:stateListAnimator="@null"
                    android:minWidth="0dp"
                    android:minHeight="0dp" />

                <androidx.appcompat.widget.AppCompatCheckBox
                    android:id="@+id/switchDriveEnabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Enabled"
                    android:textSize="14sp"
                    android:textColor="@color/inkBlack"
                    android:buttonTint="@color/inkBlack" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Notebooks are stored in a per-device subfolder inside the chosen Drive folder."
                android:textSize="12sp"
                android:textColor="@color/inkLight" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/inkBlack"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- ── Action section ─────────────────────────────────────────── -->

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBackUpNow"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Back Up Now"
                android:textSize="16sp"
                android:textColor="@color/inkBlack"
                android:textAllCaps="false"
                android:background="@drawable/shape_bordered"
                android:stateListAnimator="@null"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:enabled="false" />

            <TextView
                android:id="@+id/tvLastRun"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Last backup: never"
                android:textSize="14sp"
                android:textColor="@color/inkLight"
                android:gravity="center" />

        </LinearLayout>

    </ScrollView>

    <!-- Bottom border -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

</LinearLayout>
