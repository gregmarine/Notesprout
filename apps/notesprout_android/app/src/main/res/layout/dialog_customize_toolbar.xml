<?xml version="1.0" encoding="utf-8"?>
<!-- Customize Toolbar dialog. The placement control + instructions are a fixed header; only the
     button row list scrolls (CustomizeToolbarDialog caps rowScroll's height so the AlertDialog's
     button bar is never clipped). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Placement"
        android:textColor="@color/inkBlack"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <!-- Placement segmented control. Top/Bottom/Left/Right are live; Float is disabled until a
         later session. The active placement shows the bg_toolbar_button border via isSelected. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPlaceTop"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toolbar_button"
            android:text="Top"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:padding="2dp" />

        <Space android:layout_width="6dp" android:layout_height="0dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPlaceBottom"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toolbar_button"
            android:text="Bottom"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:padding="2dp" />

        <Space android:layout_width="6dp" android:layout_height="0dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPlaceLeft"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toolbar_button"
            android:text="Left"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:padding="2dp" />

        <Space android:layout_width="6dp" android:layout_height="0dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPlaceRight"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toolbar_button"
            android:text="Right"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:padding="2dp" />

        <Space android:layout_width="6dp" android:layout_height="0dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPlaceFloat"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toolbar_button"
            android:text="Float"
            android:textColor="@color/inkBlack"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:padding="2dp" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Drag the handle to reorder. Tap a row to show or hide it."
        android:textColor="@color/inkBlack"
        android:textSize="12sp"
        android:layout_marginBottom="12dp" />

    <!-- Only this list scrolls; the header above stays fixed. -->
    <ScrollView
        android:id="@+id/rowScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Rows are inflated into this container by CustomizeToolbarDialog. -->
        <LinearLayout
            android:id="@+id/rowContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
