<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rowRoot"
    android:layout_width="match_parent"
    android:layout_height="52dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/shape_bordered"
    android:paddingStart="6dp"
    android:paddingEnd="12dp"
    android:layout_marginBottom="6dp">

    <!-- Drag handle — touch here to reorder. -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/dragHandle"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:src="@drawable/ic_grip_vertical"
        android:contentDescription="Drag to reorder" />

    <!-- The button's own icon, for recognisability. -->
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/icon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="4dp"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:textColor="@color/inkBlack"
        android:textSize="15sp" />

    <!-- Mini-set membership toggle. Bordered (isSelected) when this button is part of the mini set. -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/miniToggle"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_toolbar_button"
        android:text="Mini"
        android:textColor="@color/inkBlack"
        android:textSize="11sp"
        android:textAllCaps="false"
        android:stateListAnimator="@null"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

    <TextView
        android:id="@+id/status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:textColor="@color/inkLight"
        android:textSize="12sp" />

</LinearLayout>
