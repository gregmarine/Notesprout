<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/tvPassphraseMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/inkBlack"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/editPassphrase"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_bordered"
        android:hint="Passphrase"
        android:textColorHint="@color/inkLight"
        android:textColor="@color/inkBlack"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:inputType="textPassword"
        android:singleLine="true" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/editPassphraseConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_bordered"
        android:hint="Confirm passphrase"
        android:textColorHint="@color/inkLight"
        android:textColor="@color/inkBlack"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:inputType="textPassword"
        android:singleLine="true"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvPassphraseError"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/inkBlack"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

</LinearLayout>
