<?xml version="1.0" encoding="utf-8"?>
<!-- Drawing screen — native equivalent of DrawingScreen in Flutter.
     Root FrameLayout: drawing container fills the entire screen; toolbar and page
     indicator overlay on top.
     z-order: drawingContainer (bottom) → toolbar → tvPageIndicator (top). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paperWhite">

    <!-- Drawing view is added here programmatically -->
    <FrameLayout
        android:id="@+id/drawingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/paperWhite" />

    <!-- Toolbar floats above the canvas.
         On BOOX, setLimitRect excludes this region from pen input.
         Height is 56dp to comfortably fit 44dp icon buttons + padding.
         toolbar_background drawable provides the 1dp inkBlack bottom border.
         Order left to right: close | divider | toc | cover | divider | pen | eraser | lasso eraser | clear | lasso | divider | undo | redo | divider | template | page index | divider | insert before | insert after | delete | copy | paste -->
    <LinearLayout
        android:id="@+id/drawingToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="@drawable/toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <!-- Close button: exits the notebook -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnClose"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_close"
            android:contentDescription="Close notebook" />

        <!-- Divider after close button -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="@color/inkBlack"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Table of Contents button -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnToc"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_toc"
            android:contentDescription="Table of Contents" />

        <!-- Cover button: set notebook cover image -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnCover"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_polaroid"
            android:contentDescription="Set cover" />

        <!-- Export button: export notebook to PDF -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnExport"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_export"
            android:contentDescription="Export notebook" />

        <!-- Divider after close/cover/export group -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="@color/inkBlack"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Pen tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPen"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_pen"
            android:contentDescription="Pen tool" />

        <!-- Eraser tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnEraser"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_eraser"
            android:contentDescription="Eraser tool" />

        <!-- Lasso eraser tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoEraser"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_lasso_eraser"
            android:contentDescription="Lasso eraser" />

        <!-- Clear page -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnClear"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_clear"
            android:contentDescription="Clear page" />

        <!-- Lasso selection tool -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLasso"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_lasso"
            android:contentDescription="Lasso selection" />

        <!-- Divider before undo/redo -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="@color/inkBlack"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Undo -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnUndo"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_undo"
            android:contentDescription="Undo" />

        <!-- Redo -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnRedo"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_redo"
            android:contentDescription="Redo" />

        <!-- Divider before template -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="@color/inkBlack"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Template picker -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnTemplate"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_template"
            android:contentDescription="Template" />

        <!-- Page index — same group as template, no separator -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPageIndex"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_files"
            android:contentDescription="Page index" />

        <!-- Flexible spacer pushes page controls to the right edge -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Divider before page controls -->
        <View
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:background="@color/inkBlack"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"/>

        <!-- Insert page before current -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnInsertPageBefore"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_insert_page_before"
            android:contentDescription="Insert page before" />

        <!-- Insert page after current -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnInsertPageAfter"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_insert_page_after"
            android:contentDescription="Insert page after" />

        <!-- Delete page -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnDeletePage"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_page_delete"
            android:contentDescription="Delete page" />

        <!-- Copy page — same group as page management controls -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnCopyPage"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_copy_page"
            android:contentDescription="Copy page" />

        <!-- Paste page — same group -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPastePage"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_paste_page"
            android:contentDescription="Paste page" />

    </LinearLayout>

    <!-- Page indicator — overlay in the lower-right corner of the drawing surface.
         Not inside the toolbar; rendered above the canvas via FrameLayout z-order. -->
    <TextView
        android:id="@+id/tvPageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:text="1 / 1"
        android:textColor="@color/inkBlack"
        android:textSize="16sp" />

    <!-- Floating selection context toolbar — appears below (or above) the lasso selection box.
         Positioned programmatically in DrawingActivity.updateFloatingSelectionToolbar().
         Contains actions that operate on the current lasso selection. -->
    <LinearLayout
        android:id="@+id/floatingSelectionToolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/shape_bordered"
        android:padding="4dp"
        android:elevation="0dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoCopy"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_copy_plus"
            android:contentDescription="Copy selection" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoCut"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_cut"
            android:contentDescription="Cut selection" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoDelete"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_lasso_delete"
            android:contentDescription="Delete selection" />

        <!-- Separator before heading actions — hidden when selection contains headings -->
        <View
            android:id="@+id/headingDivider"
            android:layout_width="1dp"
            android:layout_height="28dp"
            android:layout_marginHorizontal="2dp"
            android:background="@color/inkBlack"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnMakeHeading"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_h_1"
            android:contentDescription="Make Heading"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnUnheading"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_heading_off"
            android:contentDescription="Remove Heading"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Lasso button popup toolbar — anchored below btnLasso.
         Appears when the user taps the active lasso button while the clipboard has content.
         Dismissed on any tool switch, gesture start, paste, or outside tap. -->
    <LinearLayout
        android:id="@+id/lassoPopupToolbar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:background="@drawable/shape_bordered"
        android:padding="4dp"
        android:elevation="0dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnLassoClearClipboard"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_clipboard_x"
            android:contentDescription="Clear lasso clipboard" />

    </LinearLayout>

</FrameLayout>
