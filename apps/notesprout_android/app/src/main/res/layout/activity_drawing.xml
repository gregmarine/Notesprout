<?xml version="1.0" encoding="utf-8"?>
<!-- Drawing screen — native equivalent of DrawingScreen in Flutter.
     Root FrameLayout: drawing container fills the entire screen; toolbar and page
     indicator overlay on top.
     z-order: drawingContainer (bottom) → toolbar → tvPageIndicator (top). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/paperWhite">

    <!-- Drawing view is added here programmatically -->
    <FrameLayout
        android:id="@+id/drawingContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/paperWhite" />

    <!-- Toolbar floats above the canvas.
         On BOOX, setLimitRect excludes this region from pen input.
         Height is 48dp content; toolbar_background drawable provides the 1dp inkBlack bottom border.
         Left: Close, +, − | Right: Clear, Erase -->
    <LinearLayout
        android:id="@+id/drawingToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_gravity="top"
        android:background="@drawable/toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClose"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAddPage"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="+" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDeletePage"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="&#x2212;" />

        <!-- Undo button — disabled (inkLight tint) when the undo stack is empty -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnUndo"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_undo"
            android:contentDescription="Undo"
            android:background="@drawable/shape_bordered"
            android:scaleType="center"
            android:stateListAnimator="@null" />

        <!-- Redo button — disabled (inkLight tint) when the redo stack is empty -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnRedo"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_redo"
            android:contentDescription="Redo"
            android:background="@drawable/shape_bordered"
            android:scaleType="center"
            android:stateListAnimator="@null" />

        <!-- Flexible spacer pushes Template, Clear, and Erase to the right edge -->
        <Space
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Template picker — opens the template selection dialog -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnTemplate"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="4dp"
            android:src="@drawable/ic_template"
            android:contentDescription="Template"
            android:background="@drawable/shape_bordered"
            android:scaleType="center"
            android:stateListAnimator="@null" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnClear"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Clear" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEraser"
            style="@style/Widget.NoteSprout.ToolbarButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Erase" />

    </LinearLayout>

    <!-- Page indicator — overlay in the lower-right corner of the drawing surface.
         Not inside the toolbar; rendered above the canvas via FrameLayout z-order. -->
    <TextView
        android:id="@+id/tvPageIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:text="1 / 1"
        android:textColor="@color/inkBlack"
        android:textSize="16sp" />

</FrameLayout>
