<?xml version="1.0" encoding="utf-8"?>
<!-- TextEditDialog root — vertical stack: mode toggle / divider / formatting toolbar / divider / editor -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Mode toggle row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnModeWysiwyg"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toolbar_button"
            android:text="WYSIWYG"
            android:textColor="@color/inkBlack"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:padding="4dp" />

        <Space
            android:layout_width="8dp"
            android:layout_height="0dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnModeMarkdown"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:background="@drawable/bg_toolbar_button"
            android:text="Markdown"
            android:textColor="@color/inkBlack"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null"
            android:padding="4dp" />

    </LinearLayout>

    <!-- Divider below mode toggle -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <!-- Formatting toolbar — horizontally scrollable row of compact text buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:scrollbars="none"
        android:fillViewport="false">

        <LinearLayout
            android:id="@+id/formattingToolbar"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <!-- Bold -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtBold"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="B"
                android:textColor="@color/inkBlack"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Italic -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtItalic"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="I"
                android:textColor="@color/inkBlack"
                android:textSize="14sp"
                android:textStyle="italic"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Strikethrough -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtStrikethrough"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="S̶"
                android:textColor="@color/inkBlack"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Heading with dropdown arrow -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtHeading"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="H▾"
                android:textColor="@color/inkBlack"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@color/inkBlack" />

            <!-- Unordered list -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtUl"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="•"
                android:textColor="@color/inkBlack"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Ordered list -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtOl"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="1."
                android:textColor="@color/inkBlack"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Task checkbox -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtTask"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="☐"
                android:textColor="@color/inkBlack"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Divider -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"
                android:background="@color/inkBlack" />

            <!-- Blockquote -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtBlockquote"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="❝"
                android:textColor="@color/inkBlack"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Horizontal rule -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtHr"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="—"
                android:textColor="@color/inkBlack"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

            <!-- Link -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFmtLink"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:minWidth="0dp"
                android:background="@drawable/shape_bordered"
                android:text="[⊞]"
                android:textColor="@color/inkBlack"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="0dp"
                android:paddingBottom="0dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Divider below formatting toolbar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <!-- Markdown editor — multiline, vertically scrollable -->
    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/editMarkdown"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="240dp"
        android:maxHeight="440dp"
        android:scrollbars="vertical"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="always"
        android:gravity="top|start"
        android:background="@android:color/transparent"
        android:textColor="@color/inkBlack"
        android:textColorHint="@color/inkLight"
        android:hint="Write markdown…"
        android:textSize="15sp"
        android:inputType="textMultiLine|textCapSentences"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp" />

</LinearLayout>
