<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/llTocRowContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="12dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnTocToggle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_plus"
            android:tint="@color/inkBlack"
            android:scaleType="centerInside"
            android:stateListAnimator="@null"
            android:contentDescription="Expand or collapse" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTocPageNumber"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:textColor="@color/inkBlack"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@color/borderGray" />

        <FrameLayout
            android:id="@+id/flTocHeadingContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:clipChildren="true"
            android:clipToPadding="true">

            <TextView
                android:id="@+id/tvHeadingText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:textColor="@color/inkBlack"
                android:textSize="20sp"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:visibility="gone"
                android:ellipsize="end"
                android:singleLine="true" />

        </FrameLayout>

    </LinearLayout>

    <View
        android:id="@+id/tocItemSeparator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="24dp"
        android:background="@color/inkBlack" />

</LinearLayout>
