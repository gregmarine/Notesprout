<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Notesprout" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Brand palette — AppCompat-compatible attributes only -->
        <item name="colorPrimary">@color/inkBlack</item>
        <item name="colorPrimaryDark">@color/inkBlack</item>
        <item name="colorAccent">@color/inkBlack</item>

        <!-- No ripple / highlight anywhere -->
        <item name="android:colorControlHighlight">@android:color/transparent</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/paperWhite</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- No action bar shadow -->
        <item name="android:windowContentOverlay">@null</item>

        <!-- No activity transition animations — e-ink first, no slide/fade between screens -->
        <item name="android:windowAnimationStyle">@null</item>
    </style>


    <style name="Theme.Notesprout.Scratchpad" parent="Theme.Notesprout">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

</resources>
