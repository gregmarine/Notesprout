<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Typography ── -->

    <!-- Base required by AAPT2 for dot-notation implicit parent chain -->
    <style name="TextAppearance.Notesprout" parent="@android:style/TextAppearance">
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <style name="TextAppearance.Notesprout.DisplayLarge">
        <item name="android:textSize">57sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/inkBlack</item>
        <item name="android:letterSpacing">-0.015</item>
    </style>

    <style name="TextAppearance.Notesprout.HeadlineLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <style name="TextAppearance.Notesprout.HeadlineMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <style name="TextAppearance.Notesprout.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <style name="TextAppearance.Notesprout.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <style name="TextAppearance.Notesprout.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <style name="TextAppearance.Notesprout.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <style name="TextAppearance.Notesprout.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/inkLight</item>
    </style>

    <style name="TextAppearance.Notesprout.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/inkBlack</item>
    </style>

    <!-- ── Buttons ── -->

    <!-- Black fill, white text, 4dp radius, no elevation, no press effect -->
    <style name="Widget.Notesprout.ElevatedButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/btn_elevated_background</item>
        <item name="android:textColor">@color/paperWhite</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- White fill, black text, 1dp black stroke, 4dp radius, no press effect -->
    <style name="Widget.Notesprout.OutlinedButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/shape_bordered</item>
        <item name="android:textColor">@color/inkBlack</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

    <!-- Toolbar icon button — 44dp square, bg_toolbar_button StateListDrawable,
         10dp padding so the icon has breathing room. Selected state shows border. -->
    <style name="Widget.Notesprout.ToolbarButton" parent="">
        <item name="android:layout_width">44dp</item>
        <item name="android:layout_height">44dp</item>
        <item name="android:background">@drawable/bg_toolbar_button</item>
        <item name="android:padding">10dp</item>
        <item name="android:scaleType">fitCenter</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Transparent background, black text, no press effect -->
    <style name="Widget.Notesprout.TextButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/inkBlack</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
    </style>

</resources>
