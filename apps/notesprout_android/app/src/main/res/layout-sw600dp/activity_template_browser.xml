<?xml version="1.0" encoding="utf-8"?>
<!-- Template browser — full-screen. Top bar → breadcrumb bar → card grid → bottom toolbar. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/paperWhite">

    <!-- Top border (1dp inkBlack) — matches MainActivity -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

    <!-- Top bar: back button + "Templates" title -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBack"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Close" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvTopBarTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Templates"
            android:textColor="@color/inkBlack"
            android:textSize="18sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Collect-name bar: shown in PICK+collectName mode to enter a notebook name + confirm. -->
    <LinearLayout
        android:id="@+id/collectNameBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/editNotebookName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/shape_bordered"
            android:singleLine="true"
            android:inputType="text"
            android:textColor="@color/inkBlack"
            android:textSize="16sp"
            android:padding="8dp"
            android:hint="Notebook name" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCreate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/shape_bordered"
            android:stateListAnimator="@null"
            android:textColor="@color/inkBlack"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="CREATE" />

    </LinearLayout>

    <!-- Collect-scope bar: shown in PICK+collectName mode to choose encryption scope. -->
    <LinearLayout
        android:id="@+id/collectScopeBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/toolbar_background"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:visibility="gone">

        <RadioGroup
            android:id="@+id/scopeRadioGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/radioNoEncryption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="No Encryption"
                android:textColor="@color/inkBlack"
                android:textSize="16sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <RadioButton
                android:id="@+id/radioScopeGlobal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Encrypt (Global Passphrase)"
                android:textColor="@color/inkBlack"
                android:textSize="16sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <RadioButton
                android:id="@+id/radioScopeNotebook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Encrypt (Notebook Passphrase)"
                android:textColor="@color/inkBlack"
                android:textSize="16sp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

        </RadioGroup>

    </LinearLayout>

    <!-- Breadcrumb bar: back + scrollable breadcrumb. 1dp inkBlack bottom border via toolbar_background. -->
    <LinearLayout
        android:id="@+id/breadcrumbBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/toolbar_background"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnBreadcrumbBack"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_arrow_left"
            android:contentDescription="Up one level" />

        <HorizontalScrollView
            android:id="@+id/breadcrumbScroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/breadcrumbContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- S11: action cluster (mirrors MainActivity's breadcrumb bar) — Search/Sort/Pinned/Recents. -->
        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSearch"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_search"
            android:contentDescription="Search templates" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnClearSearch"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_x"
            android:contentDescription="Clear search"
            android:visibility="gone" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnSort"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_filter"
            android:contentDescription="Sort" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPinned"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_pinned"
            android:contentDescription="Pinned templates" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnRecents"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_clock"
            android:contentDescription="Recent templates"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Picker toolbar: shown only while in move/copy picker mode. -->
    <LinearLayout
        android:id="@+id/pickerToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/paperWhite"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/pickerTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/inkBlack"
            android:textSize="15sp"
            android:text="Move here" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPickerConfirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/shape_bordered"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:stateListAnimator="@null"
            android:textColor="@color/inkBlack"
            android:text="Move here" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnPickerCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/shape_bordered"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:stateListAnimator="@null"
            android:textColor="@color/inkBlack"
            android:text="Cancel" />

    </LinearLayout>

    <!-- Picker toolbar divider -->
    <View
        android:id="@+id/pickerToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack"
        android:visibility="gone" />

    <!-- Pinned toolbar: shown only in the Pinned view. -->
    <LinearLayout
        android:id="@+id/pinnedToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/paperWhite"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/pinnedTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:text="Pinned Templates"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnPinnedCancel"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_x"
            android:contentDescription="Exit pinned view" />

    </LinearLayout>

    <View
        android:id="@+id/pinnedToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack"
        android:visibility="gone" />

    <!-- Recents toolbar: shown only in the Recents view (PICK mode only). -->
    <LinearLayout
        android:id="@+id/recentsToolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/paperWhite"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/recentsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_gravity="center_vertical"
            android:text="Recent Templates"
            android:textSize="18sp"
            android:textColor="@color/inkBlack"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/btnRecentsCancel"
            style="@style/Widget.Notesprout.ToolbarButton"
            android:src="@drawable/ic_x"
            android:contentDescription="Exit recents view" />

    </LinearLayout>

    <View
        android:id="@+id/recentsToolbarDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack"
        android:visibility="gone" />

    <!-- Grid area: fills remaining height between breadcrumb and bottom bar. -->
    <FrameLayout
        android:id="@+id/gridContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/paperWhite" />

    <!-- Bottom bar: 1dp inkBlack top border, pagination left, action buttons right. -->
    <RelativeLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/paperWhite">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/inkBlack"
            android:layout_alignParentTop="true" />

        <!-- Pagination — centred -->
        <LinearLayout
            android:id="@+id/paginationGroup"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_centerInParent="true"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnFirstPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_page_first"
                android:contentDescription="First page" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnPrevPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_page_prev"
                android:contentDescription="Previous page" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvPage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="72dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="@color/inkBlack"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="1/1" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnNextPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_page_next"
                android:contentDescription="Next page" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnLastPage"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_page_last"
                android:contentDescription="Last page" />

        </LinearLayout>

        <!-- Action buttons — right-aligned -->
        <LinearLayout
            android:id="@+id/actionButtonsGroup"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnNewTemplateFolder"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:src="@drawable/ic_folder_plus"
                android:contentDescription="New template folder" />

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnImport"
                style="@style/Widget.Notesprout.ToolbarButton"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_template"
                android:contentDescription="Import PNG" />

        </LinearLayout>

    </RelativeLayout>

    <!-- Bottom border (1dp inkBlack) — matches MainActivity -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/inkBlack" />

</LinearLayout>
